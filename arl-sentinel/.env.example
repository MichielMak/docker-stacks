# Env vars for the arl-sentinel stack in Komodo.
# Not committed to git (matches this repo's "no .env files" convention) -
# copy/paste the filled-in values into Komodo's per-stack environment, then
# you can delete this file.

# Gotify app token for notifications (create an "ARL Sentinel" application
# in the Gotify UI to get one). Without this, the sentinel just logs
# notifications to its container logs instead.
ARL_SENTINEL_GOTIFY_TOKEN=

# Only used if you flip ATTEMPT_AUTO_LOGIN to "true" in compose.yaml
# (the headless-chrome Deezer login experiment).
DEEZER_EMAIL=
DEEZER_PASSWORD=

# Required by compose.yaml (deemix/spotizerr config mounts). If Komodo
# already applies this globally to every stack you can skip it here;
# otherwise add it with the same value used by your other stacks
# (found to be /mnt/ssd0/docker/data on the host).
# DOCKER_DATA_DIR=/mnt/ssd0/docker/data
